<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    android:padding="18dp">

    <LinearLayout
        android:id="@+id/mainRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MemoPulse"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Notes locales avec Room, MVVM, LiveData et RecyclerView"
            android:textColor="#DDE8FF"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/inputPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/inputHeadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:hint="Titre de la note"
                android:inputType="textCapSentences"
                android:textColor="@color/text_main"
                android:textColorHint="#8795B5" />

            <EditText
                android:id="@+id/inputDetails"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Description détaillée"
                android:inputType="textMultiLine|textCapSentences"
                android:textColor="@color/text_main"
                android:textColorHint="#8795B5" />

            <Button
                android:id="@+id/buttonSaveMemo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@null"
                android:text="AJOUTER LA NOTE"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonClearBoard"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_danger"
                android:backgroundTint="@null"
                android:text="VIDER LA LISTE"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/textListHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Mes notes enregistrées"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textEmptyState"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="center"
            android:text="Aucune note pour le moment.\nAjoute une première idée ✨"
            android:textAlignment="center"
            android:textColor="#EAF1FF"
            android:textSize="16sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/memoRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="10dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>